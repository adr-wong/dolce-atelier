# MCP Server — Dolce Atelier
# Copy to .env and fill in values

# Server port
PORT=3002

# Backend URL
BACKEND_URL=http://localhost:3001

# Clerk (for JWT verification + token exchange)
CLERK_SECRET_KEY=sk_test_...

# API Key (set to require X-API-Key header; leave empty for dev mode)
MCP_API_KEY=

# MCP agent token signing secret (HS256). Generate with: openssl rand -hex 32
MCP_JWT_SECRET=change-me-to-a-long-random-secret

# Lifetime of issued agent tokens, in seconds (default 3600)
MCP_TOKEN_TTL=3600

# Optional seeded machine clients (JSON array) for the OAuth client_credentials grant.
# Leave empty for the Clerk-exchange (human) flow. Example:
# MCP_CLIENTS=[{"client_id":"mcp_demo","client_secret":"demo-secret","userId":"user_demo","role":"user"}]
MCP_CLIENTS=
